#!/usr/bin/env bash

set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT_DIR"

version_line="$(sed -n 's/^version:[[:space:]]*//p' pubspec.yaml | head -n 1)"
if [[ -z "$version_line" ]]; then
  echo "Missing version in pubspec.yaml" >&2
  exit 1
fi

version_name="${version_line%%+*}"
ROOT_DIR="$ROOT_DIR" VERSION_NAME="$version_name" ruby <<'RUBY'
require "fileutils"
require "open3"

ROOT_DIR = ENV.fetch("ROOT_DIR")
VERSION_NAME = ENV.fetch("VERSION_NAME")

def git_capture(*args)
  output, status = Open3.capture2e(*args)
  [output, status.success?]
end

def in_git_repo?
  _output, success = git_capture("git", "rev-parse", "--is-inside-work-tree")
  success
end

def sanitize_mentions(text)
  text.gsub(/@([^\s]+)/) do
    handle = Regexp.last_match(1).gsub(/[^A-Za-z0-9._-]/, "")
    handle.empty? ? "" : "@#{handle}"
  end
end

def normalize_subject(text)
  normalized = sanitize_mentions(text.to_s.strip)
  normalized = normalized.sub(/\A(?:build|chore|ci|docs|feat|fix|perf|refactor|revert|style|test)(?:\([^)]+\))?!?:\s*/i, "")
  normalized = normalized.gsub(/\s+/, " ").strip

  return "" if normalized.empty?

  first_character = normalized[0]
  return normalized if first_character.nil?

  first_character.upcase + normalized[1..].to_s
end

def derive_handle(email)
  return nil if email.to_s.strip.empty?

  local = email.split("@").first.to_s
  local = local.split("+", 2).last if local.include?("+")
  handle = local.downcase.gsub(/[^a-z0-9._-]/, "")
  handle.empty? ? nil : "@#{handle}"
end

def display_contributor(contributor)
  contributor[:handle] ? "#{contributor[:name]} (#{contributor[:handle]})" : contributor[:name]
end

def compact_contributor_line(contributor, separator)
  "#{display_contributor(contributor)}: #{contributor[:changes].join(separator)}"
end

def fit_lines(lines, max_length)
  output = +""

  lines.each do |line|
    candidate = output.empty? ? line : "#{output}\n#{line}"
    if candidate.length <= max_length
      output = candidate
      next
    end

    remaining = max_length - output.length
    remaining -= 1 unless output.empty?
    break if remaining <= 1

    truncated = line[0, remaining - 1] + "…"
    output = output.empty? ? truncated : "#{output}\n#{truncated}"
    break
  end

  output
end

def read_template(path, fallback)
  File.exist?(path) ? File.read(path).strip : fallback
end

contributors = []
if in_git_repo?
  last_tag_output, tag_found = git_capture("git", "describe", "--tags", "--abbrev=0")
  revision_range = if tag_found && !last_tag_output.strip.empty?
    "#{last_tag_output.strip}..HEAD"
  else
    "HEAD"
  end

  commit_output, log_found = git_capture("git", "log", "--format=%an%x1f%ae%x1f%s", revision_range)
  if log_found
    contributor_index = {}

    commit_output.each_line do |line|
      name, email, subject = line.strip.split("\u001f", 3)
      next if subject.to_s.strip.empty?

      normalized_subject = normalize_subject(subject)
      next if normalized_subject.empty?

      key = "#{name}\u0000#{email}"
      entry = if contributor_index.key?(key)
        contributors[contributor_index[key]]
      else
        contributor_index[key] = contributors.length
        contributor = {
          name: name.to_s.strip.empty? ? "Team" : name.strip,
          handle: derive_handle(email),
          changes: [],
        }
        contributors << contributor
        contributor
      end

      entry[:changes] << normalized_subject unless entry[:changes].include?(normalized_subject)
    end
  end
end

if contributors.empty?
  contributors << {
    name: "Team",
    handle: nil,
    changes: ["Maintenance and release readiness updates."],
  }
end

android_en_lines = contributors.map { |contributor| "- #{compact_contributor_line(contributor, '; ')}" }
android_ar_lines = contributors.map { |contributor| "- #{compact_contributor_line(contributor, '؛ ')}" }

contributor_labels = contributors.map { |contributor| display_contributor(contributor) }
ios_en_lines = ["What's new in v#{VERSION_NAME}", ""]
ios_en_lines.concat(android_en_lines)
ios_en_lines << ""
ios_en_lines << "Thanks #{contributor_labels.join(', ')} — v#{VERSION_NAME}"

ios_ar_lines = ["الجديد في v#{VERSION_NAME}", ""]
ios_ar_lines.concat(android_ar_lines)
ios_ar_lines << ""
ios_ar_lines << "شكراً #{contributor_labels.join('، ')} — v#{VERSION_NAME}"

description_en_template = read_template(
  File.join(ROOT_DIR, "fastlane", "templates", "store_description.en-US.txt"),
  "2ogra is a fast, Arabic-first fare collection assistant for shared transport. It helps drivers and collectors record passenger payments, calculate change, and track open settlements during the trip."
)
description_ar_template = read_template(
  File.join(ROOT_DIR, "fastlane", "templates", "store_description.ar.txt"),
  "أجرة هو مساعد سريع لتحصيل الأجرة في المواصلات المشتركة، مصمم أولاً للعربية. يساعد السائق أو المحصل على تسجيل المدفوعات، حساب الباقي، ومتابعة التسويات المفتوحة أثناء الرحلة."
)

description_en_lines = [description_en_template, "", "Contributors in this release: #{contributor_labels.join(', ')}"]
description_ar_lines = [description_ar_template, "", "المساهمون في هذا الإصدار: #{contributor_labels.join('، ')}"]

android_en_path = File.join(ROOT_DIR, "fastlane", "metadata", "android", "en-US", "changelogs", "#{VERSION_NAME}.txt")
android_ar_path = File.join(ROOT_DIR, "fastlane", "metadata", "android", "ar", "changelogs", "#{VERSION_NAME}.txt")
android_en_description_path = File.join(ROOT_DIR, "fastlane", "metadata", "android", "en-US", "full_description.txt")
android_ar_description_path = File.join(ROOT_DIR, "fastlane", "metadata", "android", "ar", "full_description.txt")
ios_en_path = File.join(ROOT_DIR, "fastlane", "metadata", "ios", "en-US", "whats_new.txt")
ios_ar_path = File.join(ROOT_DIR, "fastlane", "metadata", "ios", "ar-SA", "whats_new.txt")
ios_en_description_path = File.join(ROOT_DIR, "fastlane", "metadata", "ios", "en-US", "description.txt")
ios_ar_description_path = File.join(ROOT_DIR, "fastlane", "metadata", "ios", "ar-SA", "description.txt")

[android_en_path, android_ar_path, android_en_description_path, android_ar_description_path, ios_en_path, ios_ar_path, ios_en_description_path, ios_ar_description_path].each do |path|
  FileUtils.mkdir_p(File.dirname(path))
end

File.write(android_en_path, fit_lines(android_en_lines, 500) + "\n")
File.write(android_ar_path, fit_lines(android_ar_lines, 500) + "\n")
File.write(android_en_description_path, fit_lines(description_en_lines, 4000) + "\n")
File.write(android_ar_description_path, fit_lines(description_ar_lines, 4000) + "\n")
File.write(ios_en_path, fit_lines(ios_en_lines, 4000) + "\n")
File.write(ios_ar_path, fit_lines(ios_ar_lines, 4000) + "\n")
File.write(ios_en_description_path, fit_lines(description_en_lines, 4000) + "\n")
File.write(ios_ar_description_path, fit_lines(description_ar_lines, 4000) + "\n")

puts "Generated release notes:"
puts "  - #{android_en_path.sub(ROOT_DIR + '/', '')}"
puts "  - #{android_ar_path.sub(ROOT_DIR + '/', '')}"
puts "  - #{android_en_description_path.sub(ROOT_DIR + '/', '')}"
puts "  - #{android_ar_description_path.sub(ROOT_DIR + '/', '')}"
puts "  - #{ios_en_path.sub(ROOT_DIR + '/', '')}"
puts "  - #{ios_ar_path.sub(ROOT_DIR + '/', '')}"
puts "  - #{ios_en_description_path.sub(ROOT_DIR + '/', '')}"
puts "  - #{ios_ar_description_path.sub(ROOT_DIR + '/', '')}"
RUBY
